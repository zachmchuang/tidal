setcps 0.5

d1 $ fast 1 $ n "[1 1] 2 [2 2] 2" # s "kick" # gain 0.8
d2 $ fast 1 $ n "1 ~ 1 ~" # s "snare" # gain 0.8
d3 $ fast 1 $ n "0 0*2 0 0*4" # s "hh" # gain 1

d4 $ slow 2 $ note "ef3 ef4 df4 ef4 gf4 [gf4 ef4] [~ bf3] [df4 ef4]" # s "lo" # legato 1 # gain 0.8
d5 $ slow 2 $ n (off 0.25 (|+12) "ef3 ef4 df4 ef4 gf4 [gf4 ef4] [~ bf3] [df4 ef4]") # s "superpiano" # legato 2 # gain 0.8
